{
  "version": "2.0.0",
  "lang": "pl",
  "project": {
    "id": "prawda-sumienia-edu",
    "brand": "Prawda Sumienia",
    "productName": "Pakiet edukacyjny Prawda Sumienia",
    "seriesName": "Rap-Ort",
    "authorCredit": "Projekt autorski Piotra Lichwały (Vibrosław)",
    "mode": "institutional-education",
    "primaryAudience": [
      "szkoła podstawowa 7-8",
      "liceum",
      "uczelnia",
      "Polonia",
      "instytucje kultury"
    ],
    "corePromise": "Pakiet umożliwia prowadzenie pracy edukacyjnej z materiałem audiowizualnym poprzez wybór działu, pytania przewodniego, projekcję, pracę ucznia przez QR oraz końcowy raport.",
    "publicPositioning": "Pakiet edukacyjny oparty na rozdziale audiowizualnym, służący pracy z historią, świadectwem, pamięcią, odpowiedzialnością odbioru oraz relacją między źródłem a interpretacją.",
    "internalPositioning": "Narzędzie dla nauczyciela pierwszego kontaktu: ma być proste, natychmiast zrozumiałe, możliwe do uruchomienia bez szkolenia i bez rozbudowanej konfiguracji."
  },
  "productStrategy": {
    "uxPriority": "clarity-over-complexity",
    "teacherFirst": true,
    "studentMobileFirst": true,
    "singlePrimaryFlow": true,
    "featureRestraint": true,
    "defaultSessionModel": "choose-section-choose-question-project-qr-report",
    "targetTeacherLearningCurve": "under-5-minutes",
    "whatThisProductIs": [
      "pakietem edukacyjnym",
      "panelem prowadzącego",
      "narzędziem do pracy z raportem ucznia",
      "warstwą towarzyszącą projekcji materiału audiowizualnego"
    ],
    "whatThisProductIsNot": [
      "grą edukacyjną",
      "rozbudowaną platformą LMS",
      "encyklopedią historyczną dla ucznia",
      "efektownym demem interaktywnych funkcji"
    ]
  },
  "simplificationRules": {
    "removeComplexInteractiveObjects": true,
    "removeMultiQrModes": true,
    "removeTeacherTimelineComplexity": true,
    "removeHotspotRequirement": true,
    "removeAdvancedStageEngineFromUI": true,
    "removeMultiplePresentationViewsAsDefault": true,
    "teacherShouldAlwaysSee": [
      "dział",
      "opis działu",
      "jak prowadzić",
      "na co uważać",
      "5 gotowych pytań",
      "pole własnego pytania",
      "przycisk fullscreen",
      "przycisk QR dla ucznia",
      "archiwum raportów"
    ],
    "teacherShouldNotNeed": [
      "czytać dokumentacji technicznej",
      "konfigurować wielu trybów",
      "obsługiwać wielu warstw obiektów",
      "rozumieć logiki sesji i kroków",
      "klikać przez wiele ekranów przed startem"
    ]
  },
  "pedagogicalFramework": {
    "coreAxes": [
      "świadectwo",
      "źródło",
      "pamięć",
      "totalitaryzm",
      "wybór pod presją",
      "odpowiedzialność odbioru"
    ],
    "teachingPosture": "restrained-guided",
    "studentExperience": "focused-reflective",
    "teacherExperience": "guided-curatorial",
    "methodologicalRules": [
      "Oddzielaj fakt, interpretację i odpowiedź osobistą.",
      "Nie wymuszaj prostego wyroku moralnego.",
      "Nie prowadź lekcji jako rankingu bohaterów i winnych.",
      "Nie utożsamiaj emocjonalnej siły dzieła z pełnią źródła historycznego.",
      "Nie przypisuj intencji osobom historycznym bez wyraźnych podstaw.",
      "Nie zamieniaj pracy edukacyjnej w publicystyczny komentarz."
    ],
    "studentFacingTone": "clear-minimal-respectful",
    "teacherFacingTone": "controlled-precise-source-aware"
  },
  "historicalIntegrity": {
    "pilecki": {
      "status": "core",
      "studentFacing": true,
      "teacherFacing": true,
      "notes": "Pilecki pozostaje centralną figurą osi projektu, ale bez hagiografii i bez uproszczeń."
    },
    "cyrankiewicz": {
      "status": "advanced-context-only",
      "studentFacing": false,
      "teacherFacing": true,
      "defaultVisibility": "hidden",
      "notes": "Cyrankiewicz nie pojawia się w podstawowej ścieżce ucznia. Może wystąpić wyłącznie w nauczycielskich notach rozszerzonych jako kontekst interpretacyjny lub historyczny."
    },
    "nazism": {
      "status": "allowed",
      "studentFacing": true,
      "teacherFacing": true
    },
    "stalinism": {
      "status": "allowed",
      "studentFacing": true,
      "teacherFacing": true
    },
    "prl": {
      "status": "allowed",
      "studentFacing": true,
      "teacherFacing": true
    },
    "namedPersonComparisons": {
      "default": "off",
      "teacherOverrideAllowed": true,
      "notes": "Porównania osób historycznych nie są osią lekcji; mogą się pojawić tylko jako ostrożny kontekst dla starszych grup."
    }
  },
