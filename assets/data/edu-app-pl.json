  "homePage": {
    "hero": {
      "eyebrow": "Pakiet edukacyjny",
      "title": "Prawda Sumienia",
      "subtitle": "Historia, świadectwo, pamięć i odpowiedzialność odbioru",
      "lead": "Pakiet do pracy szkolnej, rocznicowej i instytucjonalnej oparty na rozdziale audiowizualnym. Nauczyciel wybiera dział i pytanie przewodnie, prowadzi projekcję, a uczniowie kończą pracę indywidualnym raportem przez QR.",
      "primaryCtaLabel": "Wejdź do panelu nauczyciela",
      "secondaryCtaLabel": "Zobacz działy"
    },
    "howItWorks": {
      "title": "Jak to działa",
      "steps": [
        {
          "id": "how-01",
          "title": "Wybierz dział",
          "text": "Dobierz temat do odbiorcy, rocznicy lub celu zajęć."
        },
        {
          "id": "how-02",
          "title": "Wybierz pytanie",
          "text": "Skorzystaj z gotowych pytań albo wpisz własne."
        },
        {
          "id": "how-03",
          "title": "Prowadź projekcję",
          "text": "Wyświetl pytanie i pracuj z materiałem w trybie pełnoekranowym."
        },
        {
          "id": "how-04",
          "title": "Zakończ raportem",
          "text": "Uczniowie skanują QR, odpowiadają na telefonach i zostawiają anonimowy raport."
        }
      ]
    },
    "teacherExpectation": {
      "title": "Dla nauczyciela pierwszego kontaktu",
      "points": [
        "Nie wymaga szkolenia technicznego.",
        "Nie wymaga rozbudowanej konfiguracji.",
        "Nie wymaga osobnego systemu logowania dla ucznia.",
        "Może działać jako jednorazowa lekcja lub element wydarzenia rocznicowego."
      ]
    }
  },
